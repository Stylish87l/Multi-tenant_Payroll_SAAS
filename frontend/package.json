{
  "name": "gh-payroll-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "High-fidelity, multi-tenant PWA for Ghanaian Payroll management.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix",
    "stylelint": "stylelint \"src/**/*.{css,scss,scss}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,scss,json,md}\"",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "generate": "graphql-codegen --config codegen.yml",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "postinstall": "npx tailwindcss init -p --full || true"
  },
  "dependencies": {
    "@apollo/client": "^3.11.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.5.0",
    "graphql": "^16.9.0",
    "localforage": "^1.10.0",
    "lucide-react": "^0.420.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.2",
    "@graphql-codegen/client-preset": "^4.3.3",
    "@storybook/addon-essentials": "^8.2.5",
    "@storybook/react-vite": "^8.2.5",
    "@tailwindcss/forms": "^0.5.4",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^2.0.2",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.35.0",
    "postcss": "^8.4.40",
    "prettier": "^2.8.8",
    "stylelint": "^14.10.0",
    "stylelint-config-recommended": "^9.0.0",
    "stylelint-config-tailwindcss": "^0.0.7",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.7",
    "terser": "^5.18.0",
    "vite": "^5.3.5",
    "vite-plugin-pwa": "^0.20.1",
    "vitest": "^2.0.2"
  }
}
